#!/usr/bin/env bash
# This is sourced. Fake bang-path to help editors and linters
# shellcheck disable=SC2034  # don't warn about unused variables

# Purpose:
#  Checks and formats import statements. - Be aware: Modifies the code!
# Strengths:
#  Ensures imports are grouped and ordered correctly according to PEP 8.
# Use case:
#  Keeps imports organized and clean.
# Redundant if ruff is found

# Installation methods;
#  pip install isort  # usable on iSH
#  brew install isort
#  (Ubuntu) sudo apt install isort
#  (Alpine) sudo apk add py3-isort

# Be aware many think isort is redundant if ruff is found
# but since it is so fast, by default I keep both if found.
# If you don't want this semi-duplication, uncomment the lines below:

if command -v ruff >/dev/null && ruff check --show-settings | grep -q I001; then
    # Only disable isort if local env has ruff installed and configured
    # to handle the task
    #
    # set to /dev/null instead of "" to avoid warning
    #   missing: plugin_cmd
    #
    plugin_cmd="/dev/null"
    proj_plugin_cmd="/dev/null"
else
    plugin_cmd="isort"
    proj_plugin_cmd="isort --gitignore ."
fi

plugin_priority=90

# file extensions this plugin handles
plugin_extensions=(
    .py
    .py3
)

# file-types this plugin handles
plugin_file_types=(
    "Python script*"
)
